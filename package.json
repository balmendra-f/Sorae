{
  "name": "sorae",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "export:ios": "expo export --platform ios",
    "export:web": "expo export --platform web",
    "functions:build": "npm --prefix functions run build",
    "functions:lint": "npm --prefix functions run lint",
    "validate": "npm run lint && npm run typecheck && npm run functions:lint && npm run functions:build",
    "validate:full": "npm run validate && npm run export:ios && npm run export:web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.9",
    "expo-apple-authentication": "~56.0.4",
    "expo-asset": "~56.0.16",
    "expo-audio": "~56.0.11",
    "expo-auth-session": "~56.0.13",
    "expo-constants": "~56.0.16",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.10",
    "expo-linking": "~56.0.13",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.16",
    "expo-router": "~56.2.9",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "firebase": "^12.11.0",
    "i18next": "^26.0.8",
    "nativewind": "^4.2.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.4",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~56.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.3"
  },
  "private": true,
  "overrides": {
    "xcode": {
      "uuid": "11.1.1"
    }
  }
}
